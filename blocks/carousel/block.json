{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "cph/carousel",
  "version": "1.0.0",
  "title": "CPH Carousel",
  "category": "design",
  "icon": "images-alt2",
  "description": "Locked CPH carousel section with editable text, image, and link fields only.",
  "textdomain": "cph",
  "attributes": {
    "sectionTitle": {
      "type": "string",
      "default": "Now Playing"
    },
    "slides": {
      "type": "array",
      "default": [
        {
          "eyebrow": "New Places to Stay and Play.",
          "eyebrowMobile": "",
          "title": "CPH Barcelona",
          "titleMobile": "",
          "imageUrl": "https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=1600&h=900&fit=crop",
          "imageAlt": "CPH Barcelona",
          "imageMobileUrl": "",
          "imageMobileAlt": "",
          "ctaLabel": "Visit",
          "ctaUrl": "#"
        },
        {
          "eyebrow": "New Places to Stay and Play.",
          "eyebrowMobile": "",
          "title": "CPH NYC",
          "titleMobile": "",
          "imageUrl": "https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=1600&h=900&fit=crop",
          "imageAlt": "CPH NYC",
          "imageMobileUrl": "",
          "imageMobileAlt": "",
          "ctaLabel": "Visit",
          "ctaUrl": "#"
        }
      ]
    }
  },
  "supports": {
    "html": false,
    "align": false,
    "color": false,
    "spacing": false,
    "typography": false,
    "border": false,
    "customClassName": false
  },
  "editorScript": "file:./editor.js",
  "editorStyle": "file:../../assets/css/components/cph-carousel.css",
  "render": "file:./render.php"
}
