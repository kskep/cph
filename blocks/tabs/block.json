          "imageMobileUrl": "",
          "imageMobileAlt": "",
          "ctaLabel": "Details",
          "ctaUrl": "#"
        },
        {
          "tabLabel": "Your Room",
          "tabLabelMobile": "",
          "title": "Your Room",
          "titleMobile": "",
