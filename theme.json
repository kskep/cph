{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"customTemplates": [
		{
			"name": "blank-page",
			"postTypes": [
				"page",
				"post"
			],
			"title": "Blank Page"
		}
	],
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#F9C740",
					"name": "CPH Accent",
					"slug": "cph-coral"
				},
				{
					"color": "#D9AB2F",
					"name": "CPH Accent Dark",
					"slug": "cph-coral-dark"
				},
				{
					"color": "#FCE8A1",
					"name": "CPH Accent Light",
					"slug": "cph-butter"
				},
				{
					"color": "#ffffff",
					"name": "CPH Cream",
					"slug": "cph-cream"
				},
				{
					"color": "#1F2223",
					"name": "CPH Ink",
					"slug": "cph-ink"
				},
				{
					"color": "#161717",
					"name": "CPH Charcoal",
					"slug": "cph-charcoal"
				},
				{
					"color": "#ffffff",
					"name": "White",
					"slug": "custom-white"
				},
				{
					"color": "#161717",
					"name": "Off Black",
					"slug": "custom-off-black"
				},
				{
					"color": "#5F6466",
					"name": "Deep Grey",
					"slug": "custom-deep-grey"
				},
				{
					"color": "#8E9496",
					"name": "Mid Grey",
					"slug": "custom-mid-grey"
				},
				{
					"color": "#D8DDDF",
					"name": "Grey",
					"slug": "custom-grey"
				},
				{
					"color": "#F2F4F5",
					"name": "Light Gray",
					"slug": "custom-light-gray"
				},
				{
					"color": "transparent",
					"name": "Transparent",
					"slug": "transparent"
				}
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1200px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Small",
					"size": "clamp(.5rem, 2.5vw, 1rem)",
					"slug": "small"
				},
				{
					"name": "Medium",
					"size": "clamp(1.5rem, 4vw, 2rem)",
					"slug": "medium"
				},
				{
					"name": "Large",
					"size": "clamp(2rem, 5vw, 3rem)",
					"slug": "large"
				},
				{
					"name": "Extra Large",
					"size": "clamp(3rem, 7vw, 5rem)",
					"slug": "x-large"
				},
				{
					"name": "2xl",
					"size": "clamp(4rem, 9vw, 7rem)",
					"slug": "xx-large"
				},
				{
					"name": "3xl",
					"size": "clamp(5rem, 12vw, 9rem)",
					"slug": "xxx-large"
				},
				{
					"name": "4xl",
					"size": "clamp(6rem, 14vw, 13rem)",
					"slug": "xxxx-large"
				}
			],
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"dropCap": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Open Sans\", \"Helvetica Neue\", Arial, sans-serif",
					"name": "CPH Sans",
					"slug": "cph-sans"
				},
				{
					"fontFamily": "\"Montserrat\", \"Helvetica Neue\", Arial, sans-serif",
					"name": "CPH Display",
					"slug": "cph-display"
				},
				{
					"fontFamily": "-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Oxygen-Sans,Ubuntu,Cantarell,\"Helvetica Neue\",sans-serif",
					"name": "System",
					"slug": "system"
				},
				{
					"fontFamily": "\"Times New Roman\",\"New York\",Times,\"Noto Serif\",serif",
					"name": "Serif",
					"slug": "serif"
				},
				{
					"fontFamily": "Consolas,Menlo,Monaco,\"SF Mono\",\"DejaVu Sans Mono\",\"Roboto Mono\",\"Courier New\",Courier,monospace",
					"name": "Monospace",
					"slug": "monospace"
				},
				{
					"fontFace": [
						{
							"fontFamily": "Icon-Font",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/icon-font/icon-font-400-normal.woff"
							]
						}
					],
					"fontFamily": "Icon-Font",
					"name": "Icon-Font",
					"slug": "icon-font"
				}
			],
			"fontSizes": [
				{
					"fluid": {
						"max": "0.875rem",
						"min": "0.75rem"
					},
					"name": "XSmall",
					"size": "0.75rem",
					"slug": "xsmall"
				},
				{
					"fluid": {
						"max": "1rem",
						"min": "0.875rem"
					},
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1.125rem",
						"min": "1rem"
					},
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.75rem",
						"min": "1.5rem"
					},
					"name": "Large",
					"size": "1.5rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "2.25rem",
						"min": "2rem"
					},
					"name": "XL",
					"size": "2rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "3rem",
						"min": "2.5rem"
					},
					"name": "XXL",
					"size": "3rem",
					"slug": "xx-large"
				},
				{
					"fluid": {
						"max": "4rem",
						"min": "3rem"
					},
					"name": "Display",
					"size": "4rem",
					"slug": "display"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--custom-white)",
			"text": "var(--wp--preset--color--cph-ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--cph-sans)"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cph-display)",
					"fontWeight": "800",
					"lineHeight": "1"
				}
			}
		},
		"blocks": {
			"core/button": {
				"border": {
					"bottom": {
						"color": "var(--wp--preset--color--custom-off-black)",
						"style": "solid",
						"width": "2px"
					},
					"color": null,
					"left": {
						"color": "var(--wp--preset--color--custom-off-black)",
						"style": "solid",
						"width": "2px"
					},
					"radius": {
						"bottomLeft": "10px",
						"bottomRight": "10px",
						"topLeft": "10px",
						"topRight": "10px"
					},
					"right": {
						"color": "var(--wp--preset--color--custom-off-black)",
						"style": "solid",
						"width": "2px"
					},
					"style": null,
					"top": {
						"color": "var(--wp--preset--color--custom-off-black)",
						"style": "solid",
						"width": "2px"
					},
					"width": null
				},
				"color": {
					"background": "var(--wp--preset--color--custom-off-black)",
					"text": "var(--wp--preset--color--custom-white)"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--custom-white)"
						}
					}
				},
				"shadow": "none",
				"spacing": {
					"padding": {
						"bottom": "0.7rem",
						"left": "1.5rem",
						"right": "1.5rem",
						"top": "0.6rem"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontStyle": "normal",
					"fontWeight": "400",
					"lineHeight": "1.2"
				},
				"variations": {
					"outline": {
						"border": {
							"bottom": {
								"color": "currentColor",
								"style": "solid"
							},
							"left": {
								"color": "currentColor",
								"style": "solid"
							},
							"right": {
								"color": "currentColor",
								"style": "solid"
							},
							"top": {
								"color": "currentColor",
								"style": "solid"
							}
						},
						"spacing": {
							"padding": {
								"bottom": "0.7rem",
								"left": "1.5rem",
								"right": "1.5rem",
								"top": "0.6rem"
							}
						},
						"typography": {
							"lineHeight": "1.2"
						}
					}
				}
			},
			"core/code": {
				"border": {
					"radius": "10px"
				},
				"color": {
					"background": "var(--wp--preset--color--custom-light-gray)"
				},
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--medium)",
						"left": "var(--wp--preset--spacing--medium)",
						"right": "var(--wp--preset--spacing--medium)",
						"top": "var(--wp--preset--spacing--medium)"
					}
				},
				"typography": {
					"fontSize": "1rem"
				}
			},
			"core/comment-author-name": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/comment-date": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/comment-edit-link": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/comment-reply-link": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/details": {
				"spacing": {
					"blockGap": "5px"
				}
			},
			"core/list-item": {
				"spacing": {
					"margin": {
						"bottom": "0.5rem"
					}
				},
				"typography": {
					"lineHeight": "1.4"
				}
			},
			"core/navigation": {
				"css": "",
				"elements": {
					"link": {
						":active": {
							"color": {
								"text": "var(--wp--preset--color--custom-grey)"
							}
						},
						":focus": {
							"color": {
								"text": "var(--wp--preset--color--custom-grey)"
							}
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--custom-grey)"
							},
							"typography": {
								"textDecoration": "none"
							}
						},
						"color": {
							"text": "var(--wp--preset--color--custom-grey)"
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/paragraph": {
				"spacing": {
					"margin": {
						"bottom": "0"
					}
				},
				"typography": {
					"lineHeight": "1.4"
				}
			},
			"core/post-author-name": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-comments-form": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"lineHeight": "1.2"
				}
			},
			"core/post-content": {
				"spacing": {
					"margin": {
						"bottom": "0",
						"top": "0"
					}
				}
			},
			"core/post-date": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-excerpt": {
				"elements": {
					"link": {
						"typography": {
							"fontSize": "var(--wp--preset--font-size--small)"
						}
					}
				}
			},
			"core/post-featured-image": {
				"spacing": {
					"margin": {
						"bottom": "0"
					}
				}
			},
			"core/post-template": {
				"spacing": {
					"padding": {
						"bottom": "0",
						"top": "0"
					}
				}
			},
			"core/post-terms": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-title": {
				"typography": {
					"lineHeight": "1.2"
				}
			},
			"core/preformatted": {
				"typography": {
					"fontSize": "1rem"
				}
			},
			"core/pullquote": {
				"border": {
					"top": {
						"color": "var(--wp--preset--color--custom-mid-grey)",
						"style": "solid",
						"width": "3px"
					}
				},
				"css": "display: grid;\ngap: 20px;\n",
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--medium)",
						"top": "var(--wp--preset--spacing--small)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)"
				}
			},
			"core/query-pagination": {
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--50)",
						"top": "var(--wp--preset--spacing--50)"
					}
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"color": "var(--wp--preset--color--custom-off-black)",
						"style": "solid",
						"width": "4px"
					}
				},
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--small)",
					"margin": {
						"bottom": "var(--wp--preset--spacing--large)",
						"top": "var(--wp--preset--spacing--large)"
					},
					"padding": {
						"bottom": "0.5rem",
						"left": "var(--wp--preset--spacing--medium)",
						"right": "var(--wp--preset--spacing--medium)",
						"top": "0.5rem"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontStyle": "normal",
					"fontWeight": "300"
				}
			},
			"core/search": {
				"css": ".wp-block-search__button-inside .wp-block-search__inside-wrapper{border: none;}",
				"typography": {
					"lineHeight": "1"
				}
			},
			"core/site-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontStyle": "normal",
					"fontWeight": "700",
					"letterSpacing": "-1px"
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--custom-white)",
			"text": "var(--wp--preset--color--custom-off-black)"
		},
		"css": "",
		"elements": {
			"button": {
				"border": {
					"color": "var(--wp--preset--color--transparent)",
					"radius": "4px",
					"style": "solid",
					"width": "4px"
				},
				"color": {
					"background": "var(--wp--preset--color--custom-off-black)",
					"text": "var(--wp--preset--color--custom-grey)"
				},
				
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--30)",
						"left": "var(--wp--preset--spacing--30)",
						"right": "var(--wp--preset--spacing--30)",
						"top": "var(--wp--preset--spacing--30)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "700"
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--custom-off-black)"
				}
			},
			"cite": {
				"color": {
					"text": "var(--wp--preset--color--custom-off-black)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--system)",
					"fontStyle": "normal",
					"fontWeight": "600",
					"lineHeight": "1.1"
				}
			},
			"link": {
				":active": {
					"color": {
						"text": "var(--wp--preset--color--custom-off-black)"
					}
				},
				":focus": {
					"color": {
						"text": "var(--wp--preset--color--custom-off-black)"
					}
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--custom-deep-grey)"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--custom-off-black)"
				}
			}
		},
		"spacing": {
			"blockGap": "24px",
			"padding": {
				"left": "var(--wp--preset--spacing--50)",
				"right": "var(--wp--preset--spacing--50)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system)",
			"fontSize": "var(--wp--preset--font-size--small)"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	]
}
